{
  "learning_rate": 1e-4,                
  "max_iters": 50000,                  
  "warmup_steps": 1000,                 
  "min_lr": 5e-4,                        
  "eval_iters": 500,                     
  "batch_size": 2,                      
  "block_size": 128,                     
  "gradient_accumulation_steps": 4,     
  "device": "cuda",                      
  "dtype": "bfloat16",                       
  "ptdtype": "float32"                      
}
