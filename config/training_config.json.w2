{
  "learning_rate": 1e-4,                
  "max_iters": 60000,                  
  "warmup_steps": 1000,                 
  "min_lr": 1e-6,                        
  "eval_iters": 500,                     
  "batch_size": 2,                      
  "block_size": 128,                     
  "gradient_accumulation_steps": 4,
  "early_stopping_patience": 3,
  "device": "cuda",
  "dtype": "bfloat16",
  "ptdtype": "float32",
  "optim": "adamw_torch",
  "gradient_checkpointing": true,
  "fp16": true,
  "weight_decay": 0.01,
  "lr_scheduler_type": "cosine"
}
